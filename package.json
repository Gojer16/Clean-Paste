{
	"name": "clean-paste",
	"version": "1.0.1",
	"description": "Obsidian plugin to clean messy pasted text from AI chats, websites, and docs.",
	"main": "main.js",
	"scripts": {
		"dev": "node esbuild.config.mjs",
		"build": "tsc -noEmit -skipLibCheck && node esbuild.config.mjs production",
		"lint": "eslint main.ts src tests --ext .ts",
		"test": "vitest run",
		"test:coverage": "vitest run --coverage",
		"test:watch": "vitest",
		"version": "node version-bump.mjs && git add manifest.json versions.json"
	},
	"keywords": [
		"obsidian",
		"plugin",
		"markdown",
		"clipboard"
	],
	"author": "Orlando Ascanio",
	"license": "MIT",
	"devDependencies": {
		"@types/node": "^18.19.76",
		"@typescript-eslint/eslint-plugin": "5.29.0",
		"@typescript-eslint/parser": "5.29.0",
		"@vitest/coverage-v8": "^3.2.4",
		"builtin-modules": "3.3.0",
		"eslint": "^8.57.1",
		"esbuild": "0.17.3",
		"jsdom": "^26.0.0",
		"obsidian": "latest",
		"tslib": "2.4.0",
		"typescript": "4.7.4",
		"vitest": "^3.2.4"
	},
	"dependencies": {
		"turndown": "^7.2.1",
		"turndown-plugin-gfm": "^1.0.2"
	}
}
